# ============================================================
# SalaryBox — .gitignore
# Stack: React + TypeScript (frontend), Supabase (DB + Auth + Storage + Edge Functions)
# OS: macOS | Editor: VSCode / Cursor
# ============================================================

# ---------------------------
# macOS system files
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.AppleDouble
*.LSOverride
Icon

# ---------------------------
# Node / npm / yarn / pnpm
# ---------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------
# Build outputs
# ---------------------------
dist/
build/
out/
.next/
.nuxt/
.vite/
*.tsbuildinfo

# ---------------------------
# Environment & secrets
# ---------------------------
.env
.env.*
!.env.example
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local
secrets/
*.pem
*.key
*.crt
*.p12

# ---------------------------
# Database / migrations temp
# ---------------------------
*.sqlite
*.sqlite3
*.db
dump.sql
*.dump

# ---------------------------
# Supabase CLI
# ---------------------------
supabase/.temp/
supabase/.branches/
supabase/functions/.env

# ---------------------------
# Editor / IDE
# ---------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.history/
*.sublime-project
*.sublime-workspace

# Keep shared VSCode settings
!.vscode/extensions.json
!.vscode/tasks.json

# ---------------------------
# Testing & coverage
# ---------------------------
coverage/
.nyc_output/
jest.config.local.*
cypress/screenshots/
cypress/videos/

# ---------------------------
# Docker (local overrides)
# ---------------------------
docker-compose.override.yml
.dockerignore.local

# ---------------------------
# Logs & temp files
# ---------------------------
logs/
*.log
tmp/
temp/
.cache/

# ---------------------------
# Large binary / media assets
# (tracked via Git LFS or external storage)
# ---------------------------
# Uncomment these if you move screenshots to LFS:
# docs/screenshots/*.png
# docs/screenshots/*.jpeg
